{
  "name": "@ifsuv/web",
  "version": "0.0.0",
  "private": true,
  "description": "Webapp React + Vite + Mantine — IFSUV.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"{src,test}/**/*.{ts,tsx}\"",
    "typecheck": "tsc -b ../../packages/shared && tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "clean": "rimraf dist .turbo .tsbuildinfo*"
  },
  "dependencies": {
    "@hookform/resolvers": "3.9.1",
    "@ifsuv/shared": "workspace:*",
    "@mantine/charts": "7.15.1",
    "@mantine/core": "7.15.1",
    "@mantine/dropzone": "7.15.1",
    "@mantine/form": "7.15.1",
    "@mantine/hooks": "7.15.1",
    "@tabler/icons-react": "3.24.0",
    "@tanstack/react-query": "5.62.7",
    "@tiptap/extension-image": "2.10.4",
    "@tiptap/extension-link": "2.10.4",
    "@tiptap/extension-placeholder": "2.10.4",
    "@tiptap/pm": "2.10.4",
    "@tiptap/react": "2.10.4",
    "@tiptap/starter-kit": "2.10.4",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-hook-form": "7.54.0",
    "react-router-dom": "6.28.0",
    "recharts": "^2",
    "sweetalert2": "11.15.5",
    "sweetalert2-react-content": "5.1.0",
    "zod": "3.23.8",
    "zustand": "5.0.2"
  },
  "devDependencies": {
    "@ifsuv/config": "workspace:*",
    "@tanstack/react-query-devtools": "5.62.7",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.1.0",
    "@types/react": "18.3.17",
    "@types/react-dom": "18.3.5",
    "@vitejs/plugin-react": "4.3.4",
    "jsdom": "25.0.1",
    "vite": "5.4.11",
    "vite-tsconfig-paths": "5.1.4"
  }
}
