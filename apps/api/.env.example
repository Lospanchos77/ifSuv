NODE_ENV=development
PORT=3001
MONGO_URI=mongodb://localhost:27017/ifsuv_dev
LOG_LEVEL=debug
CORS_ORIGIN=http://localhost:5173
APP_URL=http://localhost:5173

# Sessions / cookies
SESSION_TTL_DAYS=30
COOKIE_NAME=ifsuv_sid
COOKIE_SECURE=false

# Argon2id (OWASP 2024 — laisser ces valeurs sauf si profilage perf)
ARGON2_MEMORY_COST=19456
ARGON2_TIME_COST=2

# QR tokens (JWT HS256, claims tid+kind, TTL 30j typique pour QR papier)
# Générer un secret fort : `openssl rand -hex 32`
QR_TOKEN_SECRET=dev-only-change-me-please-use-openssl-rand-hex-32-in-prod-aaaa
QR_TOKEN_TTL_DAYS=30

# Mailer (Mailhog en dev, IONOS en prod)
MAILER_HOST=localhost
MAILER_PORT=1025
MAILER_USER=
MAILER_PASS=
MAILER_FROM=IFSUV <no-reply@ifsuv.local>
MAILER_SECURE=false

# Stockage des fichiers (photos tickets) sur disque local — aucun service externe.
# Relatif = depuis apps/api en dev. En prod : volume persistant (ex. /data/storage).
STORAGE_DIR=./var/storage
