# IFSUV — Template .env de prod (copié et rempli par deploy.sh init).
# Ne PAS committer le fichier .env.production réel (il est dans .gitignore).
# Les CHANGE_ME* mongo/IP sont remplacés automatiquement par deploy.sh init.
# Les OVH_* et MAILER_* doivent être édités À LA MAIN sur le VPS après init.

# ----- Hôte public (IP ou domaine) -----
# IP (ex. 51.83.12.34) → TLS interne auto-signé. Domaine (ex. ifsuv.if77.fr) → Let's Encrypt.
# Choisi interactivement par `deploy.sh init` / `deploy.sh config` (réajustable).
DOMAIN=ifsuv.example.com

# ----- Exposition réseau (stack autonome, cohabite avec le Nginx natif 80/443) -----
# Caddy n'écoute QUE sur IFSUV_BIND_IP, port CADDY_HTTPS_PORT → 443 interne.
# => aucun conflit avec Nginx. Renseigner l'IP exacte (ex. 51.83.12.34).
# Rappel : Docker publie ce port en contournant UFW (joignable depuis Internet,
# protégé par le login). Pour restreindre, voir le bloc remote_ip du Caddyfile.
IFSUV_BIND_IP=CHANGE_ME_IP
CADDY_HTTPS_PORT=8443

# Mode TLS : letsencrypt (domaine + OVH DNS-01) | internal (IP, cert auto-signé Caddy).
# CADDY_TLS_CONF = fichier importé par Caddyfile.prod selon le mode (géré par deploy.sh).
CADDY_TLS_MODE=internal
CADDY_TLS_CONF=tls.internal.conf

# ----- API NestJS -----
NODE_ENV=production
PORT=3001
LOG_LEVEL=info
# Origin/URL publics = domaine + port non standard (cohérent avec l'accès réel).
CORS_ORIGIN=https://ifsuv.example.com:8443
APP_URL=https://ifsuv.example.com:8443

# Mongo : URI interne au compose, mongo:27017 (pas localhost).
MONGO_URI=mongodb://CHANGE_ME_USER:CHANGE_ME_PASS@mongo:27017/ifsuv_prod?authSource=admin

# ----- Sessions / cookies -----
SESSION_TTL_DAYS=30
COOKIE_NAME=ifsuv_sid
COOKIE_SECURE=true

# ----- Argon2id (OWASP 2024) -----
ARGON2_MEMORY_COST=19456
ARGON2_TIME_COST=2

# ----- Tokens QR (HS256) -----
# Secret de signature des tokens QR publics/tech (REQUIS par l'API, >= 32 caractères).
# Généré automatiquement par deploy.sh (comme les creds Mongo).
QR_TOKEN_SECRET=CHANGE_ME
QR_TOKEN_TTL_DAYS=30

# ----- Mailer (SMTP IONOS en prod) -----
MAILER_HOST=smtp.ionos.fr
MAILER_PORT=465
MAILER_USER=CHANGE_ME
MAILER_PASS=CHANGE_ME
MAILER_FROM=IFSUV <no-reply@ifsuv.example.com>
MAILER_SECURE=true

# ----- TLS : Let's Encrypt via challenge DNS-01 OVH -----
# Caddy crée/supprime le TXT _acme-challenge tout seul (aucun port public requis).
# Créer un token API sur https://api.ovh.com/createToken/ avec, sur ta zone :
#   GET/POST/DELETE  /domain/zone/{zone}/record  et  /domain/zone/{zone}/record/*
#   POST             /domain/zone/{zone}/refresh
# CADDY_DNS_MODULE doit matcher le plugin compilé (Dockerfile.caddy) si tu changes
# de fournisseur (github.com/caddy-dns/<provider>).
CADDY_DNS_MODULE=github.com/caddy-dns/ovh
OVH_ENDPOINT=ovh-eu
OVH_APPLICATION_KEY=CHANGE_ME
OVH_APPLICATION_SECRET=CHANGE_ME
OVH_CONSUMER_KEY=CHANGE_ME

# ----- Mongo (utilisé par le container mongo, pas par l'API) -----
MONGO_INITDB_ROOT_USERNAME=CHANGE_ME_USER
MONGO_INITDB_ROOT_PASSWORD=CHANGE_ME_PASS
